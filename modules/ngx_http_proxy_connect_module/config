ngx_addon_name=ngx_http_proxy_connect_module

# proxy_connect and the native ngx_http_tunnel_module both handle the CONNECT
# method and conflict at runtime (the proxy_connect POST_READ handler rejects
# CONNECT with 405 before the tunnel handler runs). The native tunnel module is
# off by default; only one CONNECT implementation may be linked at a time.
if [ "$HTTP_TUNNEL" = YES ]; then
    cat << END

$0: error: the ngx_http_proxy_connect_module conflicts with the native
ngx_http_tunnel_module. Drop --with-http_tunnel_module, or drop
--add-module=.../ngx_http_proxy_connect_module, so only one is linked.

END
    exit 1
fi

if test -n "$ngx_module_link"; then
    ngx_module_type=HTTP
    ngx_module_name=ngx_http_proxy_connect_module
    ngx_module_srcs="$ngx_addon_dir/ngx_http_proxy_connect_module.c"

    . auto/module
else
    HTTP_MODULES="$HTTP_MODULES ngx_http_proxy_connect_module"
    NGX_ADDON_SRCS="$NGX_ADDON_SRCS $ngx_addon_dir/ngx_http_proxy_connect_module.c"
fi

have=NGX_HTTP_PROXY_CONNECT . auto/have
